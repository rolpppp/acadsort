# ═══════════════════════════════════════════════════════════════════════════
# .env.example — AcadSort Configuration Template
# ═══════════════════════════════════════════════════════════════════════════
#
# INSTRUCTIONS:
# 1. Copy this file: cp backend/.env.example backend/.env
# 2. Edit backend/.env with your preferences (this file acts as defaults)
# 3. Never commit backend/.env to version control (it's in .gitignore)
#
# ═══════════════════════════════════════════════════════════════════════════

# ──────────────────────────────────────────────────────────────────────────
# APP SETTINGS
# ──────────────────────────────────────────────────────────────────────────

# App name (displayed in UI and logs)
APP_NAME=AcadSort

# Version string (shown in /health endpoint)
APP_VERSION=0.1.0

# Debug mode (enables verbose logging, Swagger docs at /docs)
# Set to true for development, false for production
DEBUG=true

# ──────────────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ──────────────────────────────────────────────────────────────────────────

# Backend server host (127.0.0.1 = localhost only, safe for desktop apps)
# DO NOT CHANGE unless you know what you're doing
HOST=127.0.0.1

# Backend server port (fixed at 8765 for Tauri sidecar compatibility)
# DO NOT CHANGE unless you understand the Tauri integration
PORT=8765

# ──────────────────────────────────────────────────────────────────────────
# FILE PATHS
# ──────────────────────────────────────────────────────────────────────────

# Downloads folder path (where AcadSort watches for new files)
# Leave empty to use OS default: ~/Downloads on macOS/Linux, ~\Downloads on Windows
DOWNLOADS_PATH=

# ──────────────────────────────────────────────────────────────────────────
# EMBEDDING MODEL SETTINGS
# ──────────────────────────────────────────────────────────────────────────

# Name of the multilingual embedding model to use
# Current model: paraphrase-multilingual-MiniLM-L12-v2 (420MB, optimized for Filipino)
# https://huggingface.co/sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_MODEL_NAME=paraphrase-multilingual-MiniLM-L12-v2

# Batch size for embedding inference (higher = faster but uses more RAM)
# Recommended: 32 (balanced for most machines)
# Increase if you have >8GB RAM, decrease for limited memory
EMBEDDING_BATCH_SIZE=32

# ──────────────────────────────────────────────────────────────────────────
# LLM (OLLAMA) SETTINGS
# ──────────────────────────────────────────────────────────────────────────

# Ollama HTTP API base URL
# Must match your Ollama installation (default: http://127.0.0.1:11434)
OLLAMA_BASE_URL=http://127.0.0.1:11434

# LLM model to use (SmolLM2 recommended for UP Tacloban context)
# Install via: ollama pull smollm2:1.7b
OLLAMA_MODEL=smollm2:1.7b

# Timeout in seconds for LLM requests (prevent hanging on slow hardware)
OLLAMA_TIMEOUT=30

# Enable LLM fallback classification (when embeddings are uncertain)
# Set to false to disable LLM and use only embeddings
OLLAMA_ENABLED=true

# ──────────────────────────────────────────────────────────────────────────
# CLASSIFICATION THRESHOLDS
# ──────────────────────────────────────────────────────────────────────────

# Confidence threshold for automatic file movement (0.0 - 1.0)
# ≥ this value → move file silently without user confirmation
# Default: 0.90 (90% sure = auto-move)
CONFIDENCE_AUTO_MOVE=0.90

# Confidence threshold for suggesting to user (0.0 - 1.0)
# ≥ this value AND < AUTO_MOVE → suggest classification and ask for confirmation
# < this value → put in review queue for manual classification
# Default: 0.70 (70% sure = ask user)
CONFIDENCE_SUGGEST=0.70

# ──────────────────────────────────────────────────────────────────────────
# FILE PROCESSING
# ──────────────────────────────────────────────────────────────────────────

# Maximum characters to extract from each file for classification
# Limits: prevents large PDFs from taking too long to process
# ~2000 chars ≈ first 2-3 pages of text (usually enough to detect course)
EXTRACTION_MAX_CHARS=2000

# Maximum file size to process (in MB)
# Files larger than this will be skipped or moved to quarantine
MAX_FILE_SIZE_MB=100

# Debounce time for filesystem watcher (in seconds)
# Prevents duplicate processing when file is still being written
# 2.0 seconds recommended for most filesystems
WATCHER_DEBOUNCE_SECONDS=2.0

# Grace period for undoing auto-moves (in seconds)
# After moving a file, user can undo within this window
UNDO_GRACE_PERIOD_SECONDS=30

# ──────────────────────────────────────────────────────────────────────────
# LOGGING
# ──────────────────────────────────────────────────────────────────────────

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
# DEBUG = verbose, INFO = normal, WARNING = only warnings and errors
LOG_LEVEL=INFO

# ═══════════════════════════════════════════════════════════════════════════
# TUNING RECOMMENDATIONS FOR YOUR SETUP
# ═══════════════════════════════════════════════════════════════════════════
#
# For Low-End Laptops (4GB RAM, no GPU):
#   EMBEDDING_BATCH_SIZE=8
#   CONFIDENCE_SUGGEST=0.65  # Be more conservative; let user decide
#   WATCHER_DEBOUNCE_SECONDS=3.0  # Give more time for processing
#
# For High-End Machines (16GB+ RAM, GPU):
#   EMBEDDING_BATCH_SIZE=64  # Faster embedding inference
#   OLLAMA_MODEL=neural-chat  # Faster model option
#   CONFIDENCE_AUTO_MOVE=0.85  # More aggressive auto-move
#
# For Campus Wi-Fi / Slow Networks:
#   OLLAMA_TIMEOUT=60  # Ollama might be slow
#   WATCHER_DEBOUNCE_SECONDS=5.0  # File I/O slower on network drives
#
# ═══════════════════════════════════════════════════════════════════════════
